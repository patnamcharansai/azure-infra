{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vmName": {
      "value": "<replace-with-your-vm-name>"  // e.g., my-vm-prod
    },
    "vmSize": {
      "value": "<replace-with-vm-size>"  // e.g., Standard_DS2_v2
    },
    "osType": {
      "value": "<replace-with-os-type>"  // Linux or Windows
    },
    "adminUsername": {
      "value": "<replace-with-admin-username>"  // e.g., azureuser
    },
    "adminPassword": {
      "reference": {
        "keyVault": {
          "id": "<replace-with-keyvault-resource-id>"  // e.g., /subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<kv-name>
        },
        "secretName": "<replace-with-secret-name>"  // e.g., vmAdminPassword
      }
    },
    "sshPublicKey": {
      "value": "<replace-with-your-ssh-public-key>"  // Optional for Linux VMs
    },
    "vnetName": {
      "value": "<replace-with-spoke-vnet-name>"  // e.g., vnet-spoke-myproject-prod
    },
    "subnetName": {
      "value": "<replace-with-subnet-name>"  // e.g., default
    },
    "enableDiskEncryption": {
      "value": true  // Set to true for security
    },
    "tags": {
      "value": {
        "Environment": "<replace-with-environment>",  // e.g., prod
        "Project": "<replace-with-project-name>"  // e.g., myproject
      }
    }
  }
}