{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vmName": {
      "value": "<replace-with-your-vm-name>"
    },
    "vmSize": {
      "value": "<replace-with-vm-size>"
    },
    "osType": {
      "value": "<replace-with-os-type>"
    },
    "adminUsername": {
      "value": "<replace-with-admin-username>"
    },
    "adminPassword": {
      "value": "<replace-with-secure-password>"
    },
    "sshPublicKey": {
      "value": "<replace-with-your-ssh-public-key>"
    },
    "vnetName": {
      "value": "<replace-with-spoke-vnet-name>"
    },
    "subnetName": {
      "value": "<replace-with-subnet-name>"
    },
    "tags": {
      "value": {
        "Environment": "<replace-with-environment>",
        "Project": "<replace-with-project-name>"
      }
    }
  }
}